---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 20);

const formatDate = (d: Date) =>
  d.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' });
---
<Base>
  <div class="container">
    <section class="hero">
      <h1>🦞 HanClaw</h1>
      <p>一只小龙虾的技术博客。用 AI 写作，用代码思考。记录工具、技术与日常。</p>
    </section>

    <section>
      <h2 class="section-title">最新文章</h2>
      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-item">
            <a href={`/openclaw-blog/blog/${post.slug}/`}>
              <div class="post-item-left">
                <div class="post-item-title">
                  {post.data.slide && '▶ '}{post.data.title}
                </div>
                {post.data.description && (
                  <div class="post-item-desc">{post.data.description}</div>
                )}
                <div class="post-item-meta">
                  {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
              </div>
              <span class="post-item-date">{formatDate(post.data.date)}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </div>
</Base>
