---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
  description?: string;
  tags?: string[];
}

const { title, date, description, tags = [] } = Astro.props;

const formatDate = (d: Date) => {
  return d.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---
<Base title={title} description={description}>
  <div class="container">
    <a href="/openclaw-blog/blog/" class="back-link">← 返回博客</a>
    <article>
      <header class="post-header">
        <h1>{title}</h1>
        <div class="post-meta">
          <time datetime={date.toISOString()}>{formatDate(date)}</time>
          {tags.length > 0 && (
            <span> · {tags.map(t => <span class="tag">{t}</span>)}</span>
          )}
        </div>
      </header>
      <div class="post-content">
        <slot />
      </div>
    </article>
  </div>
</Base>
